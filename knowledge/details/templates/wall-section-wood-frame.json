    "top": ["roof-eave", "parapet", "top-of-wall"],
    "bottom": ["foundation-spread-footing", "foundation-slab-on-grade", "floor-framing"],
    "openings": ["window-head", "window-sill", "window-jamb", "door-head", "door-jamb"]
  }
