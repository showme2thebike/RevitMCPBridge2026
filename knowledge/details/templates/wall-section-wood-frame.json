      { "op": "detailComponent", "familyName": "Nominal Cut Lumber-Section", "typeName": "2x6", "description": "Top plate", "relativeLocation": "top of stud layer" },
      { "op": "detailComponent", "familyName": "Nominal Cut Lumber-Section", "typeName": "2x6", "description": "Double top plate", "relativeLocation": "above top plate" },
      { "op": "detailComponent", "familyName": "Nominal Cut Lumber-Section", "typeName": "2x6", "description": "Bottom plate", "relativeLocation": "bottom of stud layer" }
    ]
  },

  "annotations": {
    "note": "Standard callouts for this assembly type. Place with batchDrawDetail text operations.",
    "labels": [
      "FIBER CEMENT SIDING",
      "1\" AIR GAP",
      "WEATHER RESISTANT BARRIER",
      "7/16\" OSB SHEATHING",
      "2x6 WOOD STUD @ 16\" O.C.",
      "R-21 BATT INSULATION",
      "VAPOR BARRIER",
